@{
    Layout=null;
}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Log in</title>
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
        <script src="/js/hack.js"></script>

<header>
    <nav class="navbar">
         <img onclick="openHome()" src="/Images/Hack_logo.png" alt="" class="logo">
        <ul class="nav-links">
            <li onclick="openHome()">Home</li>
            <li onclick="openAbout()">About</li>
            <li onclick="openProjects()">Projects</li>
            <li onclick="openEvents()">Events</li>
            <li onclick="openContact()">Contact</li>
        </ul>
        <div>
        <button onclick="openJoin_Us()" class="btn">Join Us</button>
        </div>
    </nav>
</header>


<div class="bg-overlay"></div>

<!-- Left Circuit -->
<div class="circuit left-circuit"></div>

<!-- Right Circuit -->
<div class="circuit right-circuit"></div>

<div class="container">

    <div class="login-card">

        <h1>
            Login <span>to Your Account</span>
        </h1>

        <p class="subtitle">
            Access your dashboard and manage your projects.
        </p>

        <form id="loginForm">

            <div class="form-group">
                <label>Email Address</label>

                <div class="input-box">
                    <i class="fa-regular fa-envelope"></i>

                    <input
                    type="email" id = "Email"
                    placeholder="Enter your email">
                </div>
            </div>

            <div class="form-group">

                <div class="label-row">
                    <label>Password</label>

                    <a href="#">
                        Forgot Password?
                    </a>
                </div>

                <div class="input-box">
                    <i class="fa-solid fa-lock"></i>

                    <input
                    type="password" id="Password"
                    placeholder="Enter your password">

                    <i class="fa-regular fa-eye eye"></i>
                </div>
            </div>

            <div class="remember">

                <input type="checkbox" checked>

                <span>Remember me</span>

            </div>

            <button class="login-btn" type="submit">

                Login

                <i class="fa-solid fa-arrow-right"></i>

            </button>

            <div class="divider">
                <span>or continue with</span>
            </div>

            <div class="social-login">

                <button type="button">
                    <i class="fa-brands fa-google"></i>
                </button>

                <button type="button">
                    <i class="fa-brands fa-github"></i>
                </button>

                <button type="button">
                    <i class="fa-brands fa-linkedin"></i>
                </button>

            </div>

            <p class="signup-text">
                Don't have an account?
                <a href="#">Sign up</a>
            </p>

        </form>

    </div>

    <!-- Bottom Features -->

    <div class="features">

        <div class="feature">

            <div class="icon">
                <i class="fa-regular fa-star"></i>
            </div>

            <h3>Build</h3>

            <p>Innovative Projects</p>

        </div>

        <div class="feature">

            <div class="icon">
                <i class="fa-solid fa-wifi"></i>
            </div>

            <h3>Learn</h3>

            <p>New Technologies</p>

        </div>

        <div class="feature">

            <div class="icon">
                <i class="fa-solid fa-users"></i>
            </div>

            <h3>Collaborate</h3>

            <p>With Community</p>

        </div>

        <div class="feature">

            <div class="icon">
                <i class="fa-solid fa-rocket"></i>
            </div>

            <h3>Grow</h3>

            <p>Your Skills</p>

        </div>

    </div>

</div>

<footer class="footer">

    <div class="footer-container">

        <!-- Logo Section -->
        <div class="footer-col">
            <div class="logo" onclick="openHome()">
               <img src="/Images/Hack_logo.png" alt="" class="logo">
                <div>
                    <h2>HACK</h2>
                </div>
            </div>

            <p>
                Hardware Acceleration Club of KUET (HACK)
            </p>

            <p>
                A community of innovators building the
                future through hardware.
            </p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
            <h3>Quick Links</h3>

            <ul>
                <li><a onclick="openHome()">Home</a></li>
                <li><a onclick="openAbout()">About</a></li>
                <li><a onclick="openProjects()">Projects</a></li>
                <li><a onclick="openEvents()">Events</a></li>
                <li><a onclick="openContact()">Contact</a></li>
            </ul>
        </div>

        <!-- Contact -->
        <div class="footer-col">
            <h3>Connect</h3>

            <div class="contact-item">
                <i class="fa-regular fa-envelope"></i>
                <span>hack@kuet.ac.bd</span>
            </div>

            <div class="contact-item">
                <i class="fa-solid fa-phone"></i>
                <span>+880 1712 345 678</span>
            </div>

            <div class="contact-item">
                <i class="fa-solid fa-location-dot"></i>
                <span>KUET Campus, Khulna-9203, Bangladesh</span>
            </div>
        </div>

        <!-- Social -->
        <div class="footer-col">
            <h3>Follow Us</h3>

            <div class="social-icons">

                <a href="https://www.facebook.com/">
                    <i class="fa-brands fa-facebook-f"></i>
                </a>

                <a href="https://www.linkedin.com/">
                    <i class="fa-brands fa-linkedin-in"></i>
                </a>

                <a href="https://www.instagram.com/">
                    <i class="fa-brands fa-instagram"></i>
                </a>

                <a href="https://www.github.com/">
                    <i class="fa-brands fa-github"></i>
                </a>

            </div>
        </div>

    </div>

    <div class="footer-bottom">
        ©️ 2026 HACK KUET. All rights reserved.
    </div>

</footer>