@{
    Layout=null;
}

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About</title>
    <link rel="stylesheet" href="/css/About.css">
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <script src="/js/hack.js"></script>

    <div class="bg">
<div class="image_container">
<header>
    <nav class="navbar">
         <img onclick="openHome()" src="/Images/Hack_logo.png" alt="" class="logo">
        <ul class="nav-links">
            <li onclick="openHome()">Home</li>
            <li onclick="openAbout()">About</li>
            <li onclick="openProjects()">Projects</li>
            <li onclick="openEvents()">Events</li>
            <li onclick="openContact()">Contact</li>
        </ul>
        <div>
        <button onclick="openJoin_Us()" class="btn">Join Us</button>
        <button onclick="openlogin()" class="btn1">Log in</button>
        </div>
    </nav>
</header>


<section class="hero">
    <div class="hero-text">
        <h2>Innovating Today,<br><span>Accelerating</span>Tomorrow</h2>
        
        <p>
            Hardware Acceleration Club of KUET (HACK) is a community of passionate minds driven by curiosity and creativity in hardware, robotics and IoT.
            We learn, build and innovate together to solve real-world problems 
        </p>

    </div>
</section>
</div>
</div>

<section class="about-info">

    <div class="info-box">
        <div class="icon">
            <i class="fa-solid fa-users"></i>
        </div>

        <div class="content">
            <h2>Our Mission</h2>
            <p>
                Empower students with knowledge, tools, and
                collaboration to create impactful hardware solutions.
            </p>
        </div>
    </div>

    <div class="info-box">
        <div class="icon">
            <i class="fa-solid fa-bullseye"></i>
        </div>

        <div class="content">
            <h2>Our Vision</h2>
            <p>
                To be a leading hub for hardware innovation
                and research at KUET and beyond.
            </p>
        </div>
    </div>

</section>


<section class="stats">
    <div class="stat-box">
        <i class="fa-solid fa-user-group"></i>
        <div>
            <h2>150+</h2>
            <h3>Members</h3>
            <p>Active innovators</p>
        </div>
    </div>

    <div class="divider"></div>

    <div class="stat-box">
        <i class="fa-solid fa-screwdriver-wrench"></i>
        <div>
            <h2>30+</h2>
            <h3>Projects</h3>
            <p>Built and deployed</p>
        </div>
    </div>

    <div class="divider"></div>

    <div class="stat-box">
        <i class="fa-regular fa-calendar"></i>
        <div>
            <h2>20+</h2>
            <h3>Workshops</h3>
            <p>Hands-on sessions</p>
        </div>
    </div>

    <div class="divider"></div>

    <div class="stat-box">
        <i class="fa-solid fa-trophy"></i>
        <div>
            <h2>15+</h2>
            <h3>Achievements</h3>
            <p>Awards and recognitions</p>
        </div>
    </div>
</section>
</div>

<section class="what-we-do">

    <div class="left-content">
        <h4>WHAT WE DO</h4>

        <h1>Learn. Build. Innovate.</h1>

        <p>
            We organize workshops, hands-on training,
            project development sessions, tech talks,
            and competitions to help students explore
            and excel in the world of hardware and
            embedded systems.
        </p>
    </div>

    <div class="cards">

        <div class="card">
            <div class="icon-box">
                <i class="fa-solid fa-microchip"></i>
            </div>

            <h2>Workshops</h2>

            <p>
                Practical sessions on Embedded Systems,
                PCB Design, IoT, FPGA, Robotics and more.
            </p>
        </div>

        <div class="card">
            <div class="icon-box">
                <i class="fa-solid fa-code"></i>
            </div>

            <h2>Projects</h2>

            <p>
                Collaborative projects that turn ideas
                into working prototypes and real solutions.
            </p>
        </div>

        <div class="card">
            <div class="icon-box">
                <i class="fa-solid fa-chalkboard"></i>
            </div>

            <h2>Events</h2>

            <p>
                Tech talks, seminars, competitions,
                and exhibitions to inspire and connect.
            </p>
        </div>

        <div class="card">
            <div class="icon-box">
                <i class="fa-solid fa-users"></i>
            </div>

            <h2>Community</h2>

            <p>
                A supportive community of learners,
                makers, and innovators growing together.
            </p>
        </div>

    </div>

</section>


<!-- our focus area -->
<section class="focus-section">
    <div class="container">
        <h2><span>Our</span> Focus Areas</h2>

        <div class="focus-grid">
            <div class="focus-card">
                <i class="fas fa-microchip"></i>
                <span>Embedded Systems</span>
            </div>

            <div class="focus-card">
                <i class="fas fa-robot"></i>
                <span>Robotics</span>
            </div>

            <div class="focus-card">
                <i class="fas fa-wifi"></i>
                <span>IoT</span>
            </div>

            <div class="focus-card">
                <i class="fas fa-project-diagram"></i>
                <span>PCB Design</span>
            </div>

            <div class="focus-card">
                <i class="fas fa-memory"></i>
                <span>FPGA</span>
            </div>

        </div>
    </div>
</section>



<section class = "rocket">
    <div class="footer">
        <div></div>
        <div class="footer-icon">
            <div class="rocket-icon">
                <i class="fa-solid fa-rocket"></i>
            </div>
            <div class="footer-content">
                <h3>Together, We Accelerate</h3>
                <p>Join us in building the future with hardware innovation</p>
            </div>
        </div>

        <div class="join-btn">
             <button class="btn">Join Us 👤</button>
        </div>

    </div>
</section>
  
