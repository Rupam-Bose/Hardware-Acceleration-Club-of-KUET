      <!-- CARD -->
      <div class="card">
          <img src="/Images/Iot Weather Station.png" alt="">
        <h3>IoT Weather Station</h3>
        <p>Real-time monitoring and analytics.</p>
        <button>View Details →</button>
      </div>

      <div class="card">
        <img src="/Images/Smart Irrigation.png" alt="">
        <h3>Smart Irrigation</h3>
        <p>Automated irrigation system using sensors.</p>
        <button>View Details →</button>
      </div>

      <div class="card">
        <img src="/Images/Robotic Arm.png" alt="">
        <h3>Robotic Arm</h3>
        <p>Precision robotic control system.</p>
        <button>View Details →</button>
      </div>

      <div class="card">
        <img src="/Images/Line follower.png" alt="">
        <h3>Line Follower</h3>
        <p>Autonomous path following robot.</p>
        <button>View Details →</button>
      </div>

      <div class="card">
        <img src="/Images/Dc Converter.png" alt="">
        <h3>DC Converter</h3>
        <p>Efficient power conversion system.</p>
        <button>View Details →</button>
      </div>
            
      <div class="card">
        <img src="/Images/Drone.png" alt="">
        <h3>Autonomous Surveillance Drone</h3>
        <p>
          Quadcopter flying drone
        </p>
        <button>View Details →</button>
      </div>

    </div>

  </div>

