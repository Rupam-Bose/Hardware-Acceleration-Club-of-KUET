@{
    Layout=null;
}
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact</title>
    <link rel="stylesheet" href="/css/Contact.css">
        <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <script src="/js/hack.js"></script>

<header>
    <nav class="navbar">
         <img onclick="openHome()" src="/Images/Hack_logo.png" alt="" class="logo">
        <ul class="nav-links">
            <li onclick="openHome()">Home</li>
            <li onclick="openAbout()">About</li>
            <li onclick="openProjects()">Projects</li>
            <li onclick="openEvents()">Events</li>
            <li onclick="openContact()">Contact</li>
        </ul>
        <div>
        <button onclick="openJoin_Us()" class="btn">Join Us</button>
        <button onclick="openlogin()" class="btn1">Log in</button>
        </div>
    </nav>
</header>

<section class="contact-section">

    <div class="contact-container">

        <div class="contact-info">

            <span class="subtitle">GET IN TOUCH</span>

            <h3>
                Let's Build Something
                Amazing <span>Together.</span>
            </h3>

            <p class="description">
                Have a question, an idea, or want to collaborate?
                We'd love to hear from you. Reach out to us and let's
                turn your ideas into reality.
            </p>
            <div class="info">
            <div class="info-box">
                <div class="icon">
                <i class="fa-solid fa-envelope"></i>
                 </div>
                <div>
                    <h4>Email</h4>
                    <p>hack@kuet.ac.bd</p>
                </div>
            </div>

            <div class="info-box">
                <div class="icon">
                <i class="fa-solid fa-phone"></i>
                 </div>
                <div>
                    <h4>Phone</h4>
                    <p>+880 1712 345 678</p>
                </div>
            </div>

            <div class="info-box">
                <div class="icon">
                <i class="fa-solid fa-location-dot"></i>
                </div>                
                <div>
                    <h4>Location</h4>
                    <p>KUET Campus, Khulna-9203, Bangladesh</p>
                </div>
            </div>
            </div>


            <div class="social">
                <h4>Follow Us</h4>

                <div class="social-icons">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-github"></i></a>
                </div>
            </div>

        </div>

        <!-- Right Side -->
        <div class="contact-form">

            <div class="form-header">
                <div class="form-icon">
                    <i class="fa-regular fa-paper-plane"></i>
                </div>

                <div>
                    <h2>Send Us a Message</h2>
                    <p>Fill out the form below and we will get back to you soon.</p>
                </div>
            </div>

            <form>

                <div class="row">
                    <input type="text" placeholder="Your Name">
                    <input type="email" placeholder="Your Email">
                </div>

                <input type="text" placeholder="Subject">

                <textarea rows="8" placeholder="Your Message"></textarea>

                <button type="submit">
                    <i class="fa-regular fa-paper-plane"></i>
                    Send Message
                </button>

            </form>

        </div>

    </div>

</section>


<footer class="footer">

    <div class="footer-container">

        <!-- Logo Section -->
        <div class="footer-col">
            <div class="logo">
               <img src="/Images/Hack_logo.png" alt="" class="logo">
                <div>
                    <h2>HACK</h2>
                </div>
            </div>

            <p>
                Hardware Acceleration Club of KUET (HACK)
            </p>

            <p>
                A community of innovators building the
                future through hardware.
            </p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
            <h3>Quick Links</h3>

            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#">About</a></li>
                <li><a href="#">Projects</a></li>
                <li><a href="#">Events</a></li>
                <li><a href="#">Team</a></li>
            </ul>
        </div>

        <!-- Contact -->
        <div class="footer-col">
            <h3>Connect</h3>

            <div class="contact-item">
                <i class="fa-regular fa-envelope"></i>
                <span>hack@kuet.ac.bd</span>
            </div>

            <div class="contact-item">
                <i class="fa-solid fa-phone"></i>
                <span>+880 1712 345 678</span>
            </div>

            <div class="contact-item">
                <i class="fa-solid fa-location-dot"></i>
                <span>KUET Campus, Khulna-9203, Bangladesh</span>
            </div>
        </div>

        <!-- Social -->
        <div class="footer-col">
            <h3>Follow Us</h3>

            <div class="social-icons">

                <a href="#">
                    <i class="fa-brands fa-facebook-f"></i>
                </a>

                <a href="#">
                    <i class="fa-brands fa-linkedin-in"></i>
                </a>

                <a href="#">
                    <i class="fa-brands fa-instagram"></i>
                </a>

                <a href="#">
                    <i class="fa-brands fa-github"></i>
                </a>

            </div>
        </div>

    </div>

    <div class="footer-bottom">
        © 2024 HACK KUET. All rights reserved.
    </div>

</footer>
