@{
    Layout = null;
}

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Join Us</title>

<link rel="stylesheet" href="/css/Join_Us.css">
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<script src="/js/hack.js"></script>

<header>
    <nav class="navbar">
        <img onclick="openHome()" src="/Images/Hack_logo.png" alt="" class="logo">
        <ul class="nav-links">
            <li onclick="openHome()">Home</li>
            <li onclick="openAbout()">About</li>
            <li onclick="openProjects()">Projects</li>
            <li onclick="openEvents()">Events</li>
            <li onclick="openContact()">Contact</li>
        </ul>
        <div>
            <button onclick="openlogin()" class="btn1">Log in</button>
        </div>
    </nav>
</header>

<div class="background"></div>

<div class="container">

    <div class="signup-card">

        <h1>Create <span>Your Account</span></h1>
        <p class="subtitle">
            Join KUET Tech Community and start building.
        </p>

        <!-- ✅ ADDED ID ONLY -->
        <form id="signupForm">

            <div class="row">
                <div class="input-group">
                    <label>Full Name</label>
                    <div class="input-box">
                        <i class="fa-regular fa-user"></i>
                        <input type="text" id="FullName" placeholder="Enter your full name">
                    </div>
                </div>

                <div class="input-group">
                    <label>Username</label>
                    <div class="input-box">
                        <i class="fa-solid fa-at"></i>
                        <input type="text" id="Username" placeholder="Choose a username">
                    </div>
                </div>
            </div>

            <div class="input-group full">
                <label>Email Address</label>
                <div class="input-box">
                    <i class="fa-regular fa-envelope"></i>
                    <input type="email" id="Email" placeholder="Enter your email">
                </div>
            </div>

            <div class="row">
                <div class="input-group">
                    <label>Department</label>
                    <div class="input-box">
                        <i class="fa-solid fa-building-columns"></i>

                        <select id="Department">
                            <option value="">Select your department</option>
                            <option value="CSE">CSE</option>
                            <option value="EEE">EEE</option>
                            <option value="ME">ME</option>
                            <option value="CE">CE</option>
                        </select>

                        <i class="fa-solid fa-chevron-down right-icon"></i>
                    </div>
                </div>

                <div class="input-group">
                    <label>Batch / Session</label>
                    <div class="input-box">
                        <i class="fa-regular fa-calendar"></i>

                        <select id="BatchSession">
                            <option value="">Select your batch</option>
                            <option value="2K21">2K21</option>
                            <option value="2K22">2K22</option>
                            <option value="2K23">2K23</option>
                            <option value="2k24">2K24</option>
                        </select>

                        <i class="fa-solid fa-chevron-down right-icon"></i>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="input-group">
                    <label>Password</label>
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" id="PasswordHash" placeholder="Create a password">
                        <i class="fa-regular fa-eye right-icon"></i>
                    </div>
                </div>

                <div class="input-group">
                    <label>Confirm Password</label>
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input type="password" id="ConfirmPassword" placeholder="Confirm your password">
                        <i class="fa-regular fa-eye right-icon"></i>
                    </div>
                </div>
            </div>

            <div class="checkbox">
                <input type="checkbox" checked>
                <label>
                    I agree to the Terms of Service and Privacy Policy
                </label>
            </div>

            <!-- IMPORTANT: submit -->
            <button type="submit" class="signup-btn">
                Sign Up
                <i class="fa-solid fa-arrow-right"></i>
            </button>

        </form>

    </div>

</div>